alias ..='cd ..'
alias ...='cd ../..'
alias .3='cd ../../..'
alias .4='cd ../../../..'
alias .5='cd ../../../../..'
alias .6='cd ../../../../../..'
alias c='clear'
alias df='df -h'
alias diff='diff --color'
alias docker='sudo docker'
alias free='free -h'
alias grep='grep --color=auto'
alias gogh='bash -c "$(wget -qO- https://git.io/vQgMr)"'
alias list-users='compgen -u'
alias list-groups='compgen -g'
alias lsv='ls -lahF'
alias mkdir='mkdir -p'
alias please='sudo $(fc -ln -1)'
alias update='sudo apt update && sudo apt upgrade -y'
alias wc='echo "lines words chars name" && wc'
